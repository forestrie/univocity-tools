{
  "name": "@univocity-tools/deployer",
  "version": "0.6.0",
  "private": true,
  "description": "CLI for Univocity contract deployment",
  "type": "module",
  "bin": {
    "deployer": "./dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outdir dist --target bun",
    "build:binary": "bun ../../scripts/build-binary.ts --app deployer",
    "build:binary:linux-x64": "bun ../../scripts/build-binary.ts --app deployer --target bun-linux-x64",
    "build:binary:darwin-arm64": "bun ../../scripts/build-binary.ts --app deployer --target bun-darwin-arm64",
    "dev": "bun run ./src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@univocity-tools/deployer-common": "workspace:*",
    "citty": "^0.2.2"
  },
  "files": [
    "dist"
  ]
}
