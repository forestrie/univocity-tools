{
    // Arachnid proxy address, often already deployed on many chains.
    "proxy": "0x4e59b44847b379578588920cA78FbF26c0B4956C",
    // Raw deployment transaction for Arachnid proxy.
    "deploy-tx": "",
    // Signer address for Arachnid proxy deployment, you need to send funds to this account to deploy with the arachnid proxy.
    "signer": "0x3fAB184622Dc19b6109349B94811493BF2a45362",
    // CREATE3 factory address - the address the create3 factory will be deployed to.
    "factory": "0x988e1Ef32F200E84197266eC0Fd36cC9a1d849dF",
    // CREATE3 salt for UUPSUnivocity proxy (predictable genesis address).
    "uups-salt": "forestrie.eth/univocity/UUPSUnivocity/0"
}
